r <- data_plot %>%
ggplot(aes(x = informationSource, y = update, color = scienceTeam)) +
stat_summary(
fun.data = mean_cl_boot,
geom = "point",
position = position_dodge(0.5),
size = 3
) +
stat_summary(
fun.data = mean_cl_boot,
geom = "errorbar",
width = 0.2,
position = position_dodge(0.5),
linewidth = 0.8
) +
labs(
x = "Directness of Information",
y = "Mean Change of Causal Confidence",
color = "Speaker Goal Orientation"
) +
theme_aida() +
theme(
legend.position = "top",
text = element_text(size = 16),
axis.text = element_text(size = 14),
strip.text = element_text(size = 16),
axis.title.y = element_text(size = 16)
)
r
ggsave("results_exp_3", plot = r, width = 8, height = 6, dpi = 300)
