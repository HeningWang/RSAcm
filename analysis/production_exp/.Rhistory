data_brm |>
dplyr::select(condition) |>
unique() |>
tidybayes::add_epred_draws(
fit,
ndraws = 8000,
allow_new_levels = TRUE
) |>
pivot_wider (
names_from = .category,
values_from = .epred
) |>
filter(condition != "info") |>
group_by(condition) |>
summarize(
post_prob_hypothesis = mean(match > `non-match-2`)
)
